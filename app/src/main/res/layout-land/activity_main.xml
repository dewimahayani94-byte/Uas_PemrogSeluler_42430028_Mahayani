<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/awesome_white"
    android:baselineAligned="false">

    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@color/white"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Galaxy A"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/awesome_graphite" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filter &amp; Sortir"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pencarian"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/et_search_land"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:background="@drawable/bg_badge_series"
            android:backgroundTint="@color/awesome_white"
            android:hint="Cari seri..."
            android:paddingHorizontal="12dp"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Urutan Nama"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/rg_sort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/rb_sort_asc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ascending (A-Z)"
                android:textSize="13sp"/>

            <RadioButton
                android:id="@+id/rb_sort_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Descending (Z-A)"
                android:textSize="13sp"/>

        </RadioGroup>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_samsung_catalog_land"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:clipToPadding="false"
        tools:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        tools:spanCount="2"
        tools:listitem="@layout/item_samsung" />

</LinearLayout>